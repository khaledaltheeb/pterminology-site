  "privacy_requirements": {
    "default_server_transmission": false,
    "local_storage_requires_explicit_opt_in": true,
    "consent_must_be_withdrawable": true,
    "must_state_retention_period_or_session_scope": true,
    "must_explain_export": true,
    "must_explain_complete_deletion": true,
    "must_confirm_deletion_result": true,
    "must_warn_against_identifying_free_text": true,
    "must_name_third_party_processing_when_present": true,
    "non_essential_cookies_require_prior_consent": true,
    "analytics_must_not_receive_sensitive_tool_entries": true
  },
  "data_lifecycle_requirements": {
    "retention_must_be_specific": true,
    "indefinite_retention_is_forbidden_without_documented_necessity": true,
    "withdrawal_must_stop_future_optional_storage": true,
    "withdrawal_must_not_silently_delete_without_warning": true,
    "delete_all_must_cover_all_local_keys_owned_by_the_tool": true,
    "deletion_must_be_idempotent": true,
    "deletion_failure_must_be_reported_accessibly": true
  },
  "result_safety_requirements": {
    "must_state_not_diagnostic": true,
    "must_not_claim_to_confirm_or_exclude_a_disorder": true,
    "must_explain_next_step": true,
    "must_distinguish_education_from_professional_care": true,
    "sensitive_results_require_professional_help_guidance": true,
    "emergency_guidance_requires_urgent_level_or_explicit_escalation": true,
    "urgent_results_require_local_emergency_guidance": true
  },
