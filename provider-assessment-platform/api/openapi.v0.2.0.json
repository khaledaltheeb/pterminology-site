{
  "openapi": "3.1.0",
  "info": {
    "title": "Provider Assessment Platform API",
    "version": "0.2.0",
    "description": "Governed draft API for provider assessment workflows. It cannot expose protected test materials, generate an automatic diagnosis, decide legal eligibility, or sign a report without an authorized human reviewer."
  },
  "servers": [
    {
      "url": "https://assessment-api.invalid/v1",
      "description": "Non-routable placeholder. No service is deployed."
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/cases": {
      "post": {
        "operationId": "createCase",
        "summary": "Create a governed case record",
        "security": [
          {
            "oauth2": ["case:create"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaseCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Case created",
            "headers": {
              "X-Audit-Event-Id": {
                "$ref": "#/components/headers/AuditEventId"
              },
              "ETag": {
                "$ref": "#/components/headers/ETag"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaseRecord"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      },
      "get": {
        "operationId": "listAssignedCases",
        "summary": "List cases assigned to the authenticated provider",
        "security": [
          {
            "oauth2": ["case:read-assigned"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "responses": {
          "200": {
            "description": "Assigned cases",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CaseSummary"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/cases/{case_id}": {
      "get": {
        "operationId": "getAssignedCase",
        "summary": "Read an assigned case without protected assessment content",
        "security": [
          {
            "oauth2": ["case:read-assigned"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "responses": {
          "200": {
            "description": "Case record",
            "headers": {
              "ETag": {
                "$ref": "#/components/headers/ETag"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaseRecord"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "operationId": "updateAssignedCase",
        "summary": "Apply a versioned update to an assigned case",
        "security": [
          {
            "oauth2": ["case:update-assigned"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          },
          {
            "$ref": "#/components/parameters/IfMatch"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/merge-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/CaseUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Case updated",
            "headers": {
              "X-Audit-Event-Id": {
                "$ref": "#/components/headers/AuditEventId"
              },
              "ETag": {
                "$ref": "#/components/headers/ETag"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaseRecord"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "412": {
            "$ref": "#/components/responses/PreconditionFailed"
          }
        }
      }
    },
    "/cases/{case_id}/safety-events": {
      "post": {
        "operationId": "createSafetyEvent",
        "summary": "Create or escalate a safety event and block routine routing when required",
        "security": [
          {
            "oauth2": ["safety:create"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SafetyEventRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Safety event created",
            "headers": {
              "X-Audit-Event-Id": {
                "$ref": "#/components/headers/AuditEventId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SafetyEvent"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/cases/{case_id}/pathway-evaluations": {
      "post": {
        "operationId": "evaluatePathwayNode",
        "summary": "Evaluate one governed pathway node",
        "description": "Returns an explainable next-step decision only. It cannot return a diagnosis, legal eligibility decision, or automatic report approval.",
        "security": [
          {
            "oauth2": ["pathway:evaluate"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PathwayEvaluationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Explainable next-step decision",
            "headers": {
              "X-Audit-Event-Id": {
                "$ref": "#/components/headers/AuditEventId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PathwayDecision"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/cases/{case_id}/assessment-access-checks": {
      "post": {
        "operationId": "checkAssessmentAccess",
        "summary": "Run a fail-closed provider, institution, tool, and case access check",
        "security": [
          {
            "oauth2": ["assessment:access-check"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssessmentAccessRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fail-closed access decision",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssessmentAccessDecision"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/cases/{case_id}/sessions": {
      "post": {
        "operationId": "startAssessmentSession",
        "summary": "Start a session after a current successful access check",
        "description": "Protected items remain inside an approved publisher integration boundary and are not returned by this API contract.",
        "security": [
          {
            "oauth2": ["session:start"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionStartRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session started",
            "headers": {
              "X-Audit-Event-Id": {
                "$ref": "#/components/headers/AuditEventId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssessmentSession"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/cases/{case_id}/sessions/{session_id}/complete": {
      "post": {
        "operationId": "completeAssessmentSession",
        "summary": "Complete, stop, or invalidate a session with validity metadata",
        "security": [
          {
            "oauth2": ["session:complete"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/SessionId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionCompleteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session completed, stopped, or invalidated",
            "headers": {
              "X-Audit-Event-Id": {
                "$ref": "#/components/headers/AuditEventId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssessmentSession"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/cases/{case_id}/reports/drafts": {
      "post": {
        "operationId": "createReportDraft",
        "summary": "Create an unsigned report draft from allowed evidence",
        "description": "The output is always a draft requiring human review. Protected test materials are excluded.",
        "security": [
          {
            "oauth2": ["report:draft"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportDraftRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Unsigned report draft",
            "headers": {
              "X-Audit-Event-Id": {
                "$ref": "#/components/headers/AuditEventId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportDraft"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/cases/{case_id}/reports/{report_id}/sign": {
      "post": {
        "operationId": "signReport",
        "summary": "Sign a report after an authorized clinical review",
        "security": [
          {
            "oauth2": ["report:sign"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/ReportId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportSignRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signed report",
            "headers": {
              "X-Audit-Event-Id": {
                "$ref": "#/components/headers/AuditEventId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignedReport"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/cases/{case_id}/audit-events": {
      "get": {
        "operationId": "listCaseAuditEvents",
        "summary": "List immutable audit metadata for an authorized reviewer",
        "security": [
          {
            "oauth2": ["audit:read"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CaseId"
          },
          {
            "$ref": "#/components/parameters/CorrelationId"
          }
        ],
        "responses": {
          "200": {
            "description": "Audit events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AuditEvent"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "Authorization code flow with PKCE and institution-scoped claims.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://identity.invalid/oauth2/authorize",
            "tokenUrl": "https://identity.invalid/oauth2/token",
            "scopes": {
              "case:create": "Create cases",
              "case:read-assigned": "Read assigned cases",
              "case:update-assigned": "Update assigned cases",
              "safety:create": "Create safety events",
              "pathway:evaluate": "Evaluate governed pathway nodes",
              "assessment:access-check": "Check assessment access",
              "session:start": "Start authorized sessions",
              "session:complete": "Complete assigned sessions",
              "report:draft": "Create unsigned report drafts",
              "report:sign": "Sign reports as an authorized reviewer",
              "audit:read": "Read audit metadata"
            }
          }
        }
      }
    },
    "parameters": {
      "CaseId": {
        "name": "case_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^CASE-[A-Z0-9-]{8,40}$"
        }
      },
      "SessionId": {
        "name": "session_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^SES-[A-Z0-9-]{8,40}$"
        }
      },
      "ReportId": {
        "name": "report_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^RPT-[A-Z0-9-]{8,40}$"
        }
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 16,
          "maxLength": 128
        }
      },
      "CorrelationId": {
        "name": "X-Correlation-Id",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128
        }
      },
      "IfMatch": {
        "name": "If-Match",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "headers": {
      "AuditEventId": {
        "description": "Immutable audit event identifier",
        "schema": {
          "type": "string",
          "pattern": "^AUD-[A-Z0-9-]{8,50}$"
        }
      },
      "ETag": {
        "description": "Optimistic concurrency token",
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "ValidationError": {
        "description": "Request validation failed",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required or invalid",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "Forbidden": {
        "description": "The actor lacks the required institution, case, professional, or tool scope",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found within the authorized scope",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "Conflict": {
        "description": "Workflow, safety, licensing, or state conflict",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "PreconditionFailed": {
        "description": "The supplied version token is stale",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      }
    },
    "schemas": {
      "CaseStatus": {
        "type": "string",
        "enum": [
          "intake",
          "safety_hold",
          "assessment_planning",
          "in_assessment",
          "multidisciplinary_review",
          "report_draft",
          "approved",
          "closed",
          "withdrawn"
        ]
      },
      "Subject": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "date_of_birth",
          "age_months_at_intake",
          "preferred_language",
          "communication_modes",
          "country_of_service"
        ],
        "properties": {
          "date_of_birth": {
            "type": "string",
            "format": "date"
          },
          "age_months_at_intake": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1440
          },
          "preferred_language": {
            "type": "string",
            "minLength": 2
          },
          "home_languages": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "education_languages": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "communication_modes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "country_of_service": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          }
        }
      },
      "Consent": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "legal_basis",
          "obtained_at",
          "scope",
          "withdrawal_explained"
        ],
        "properties": {
          "legal_basis": {
            "type": "string",
            "enum": [
              "guardian_consent",
              "adult_consent",
              "authorized_representative",
              "other_documented_basis"
            ]
          },
          "obtained_at": {
            "type": "string",
            "format": "date-time"
          },
          "scope": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "withdrawal_explained": {
            "const": true
          },
          "document_reference": {
            "type": "string"
          }
        }
      },
      "Referral": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reason",
          "questions",
          "referrer_role"
        ],
        "properties": {
          "reason": {
            "type": "string",
            "minLength": 10
          },
          "questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 5
            }
          },
