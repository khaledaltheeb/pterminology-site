{
  "id": "reading-writing-learning",
  "names": {
    "ar": "مسار تقييم صعوبات القراءة والكتابة والتعلم الأكاديمي",
    "en": "Reading, Writing, and Academic Learning Assessment Pathway"
  },
  "version": "0.1.0",
  "status": "draft",
  "scope": {
    "purpose": "تنظيم تقييم شامل لصعوبات القراءة والكتابة والتهجئة والتعبير مع تحليل اللغة والتعليم والاستجابة للتدخل والوظيفة الأكاديمية.",
    "age_min_months": 60,
    "age_max_months": 252,
    "included_questions": [
      "ما المهارات الأكاديمية المحددة المتأثرة وما أثرها؟",
      "هل تلقى المتعلم تعليمًا كافيًا ومناسبًا باللغة والمنهج؟",
      "ما العلاقة بين اللغة المنطوقة والوعي الصوتي والقراءة والكتابة؟",
      "هل توجد عوامل سمعية أو بصرية أو معرفية أو انتباهية أو عاطفية مصاحبة؟",
      "كيف استجاب المتعلم للتعليم أو التدخل الموثق؟"
    ],
    "excluded_uses": [
      "تشخيص اضطراب تعلم من درجة تحصيل منخفضة منفردة",
      "تجاهل جودة التعليم والحضور واللغة والمنهج",
      "استخدام معايير لغة أو نظام كتابة غير مناسب دون الإفصاح",
      "الاعتماد على فرق الذكاء والتحصيل وحده",
      "حساب أهلية تعليمية قانونية تلقائيًا"
    ],
    "countries": ["JO"],
    "languages": ["ar", "en"]
  },
  "entry": {
    "start_node": "learning-referral-review",
    "required_case_fields": [
      "case_id",
      "subject.age_months_at_intake",
      "subject.home_languages",
      "subject.education_languages",
      "consent.obtained_at",
      "referral.questions",
      "safety.level"
    ],
    "blocking_conditions": [
      "غياب الموافقة أو سؤال تعليمي محدد",
      "العمر أو المرحلة خارج نطاق المسار",
      "غياب معلومات اللغة والمنهج والصف",
      "عدم توفر مختص مؤهل للتقييم التعليمي واللغوي"
    ],
    "minimum_role": "educational_psychologist"
  },
  "global_rules": {
    "minimum_independent_sources": 2,
    "require_direct_observation": true,
    "require_functional_profile": true,
    "require_multidisciplinary_review": true,
    "prohibit_single_tool_conclusion": true,
    "conflict_policy": "يحلل اختلاف الاختبارات وعينات الصف والاستجابة للتعليم ولا يمنح الأولوية للدرجة المعيارية دون فحص صلاحيتها والسياق.",
    "missing_data_policy": "غياب سجل التعليم أو اللغة أو عينات العمل أو بيانات الاستجابة للتدخل يبقي التفسير محدودًا أو غير حاسم."
  },
  "nodes": [
    {
      "id": "learning-referral-review",
      "type": "intake",
      "label": {"ar": "مراجعة إحالة القراءة والكتابة", "en": "Reading and writing referral review"},
      "required_roles": ["educational_psychologist", "special_educator", "case_lead"],
      "preconditions": ["إحالة وموافقة"],
      "actions": [
        "تحديد المهارات والمواقف الأكاديمية المتأثرة",
        "جمع مخاوف المتعلم والأسرة والمعلم وأهداف التقييم",
        "تحديد اللغة والمنهج والصف وتاريخ الصعوبة"
      ],
      "required_evidence": ["referral.questions", "consent.obtained_at", "subject.education_languages"],
      "transitions": [
        {
          "id": "accept-learning-pathway",
          "priority": 1,
          "condition": {
            "all": [
              {"exists": "referral.questions"},
              {"exists": "consent.obtained_at"},
              {"exists": "subject.education_languages"},
              {"in": ["safety.level", ["none_identified", "monitor"]]}
            ]
          },
          "destination": "instruction-opportunity-review",
          "explanation": {
            "ar": "الإحالة واللغة التعليمية موثقتان ويمكن مراجعة جودة وفرص التعليم السابقة.",
            "en": "Referral and instructional language are documented; prior instructional quality and opportunity can be reviewed."
          },
          "source_ids": ["ASHA-WRITTEN-LANGUAGE"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        }
      ],
      "failure_behavior": "request_missing_data",
      "maximum_age_hours": 168
    },
    {
      "id": "instruction-opportunity-review",
      "type": "record_review",
      "label": {"ar": "مراجعة التعليم وفرص التعلم", "en": "Instruction and learning opportunity review"},
      "required_roles": ["educational_psychologist", "special_educator", "teacher", "case_lead"],
      "preconditions": ["قبول الإحالة"],
      "actions": [
        "مراجعة الحضور والاستمرارية وجودة التعليم والمنهج واللغة المستخدمة",
        "جمع بيانات الأداء الصفية والتدخلات السابقة ومدتها ودقتها",
        "توثيق التغير المتوقع والفعلـي والاستجابة للتدريس"
      ],
      "required_evidence": [
        "instruction_review.attendance_complete",
        "instruction_review.curriculum_complete",
        "instruction_review.interventions",
        "instruction_review.response_data"
      ],
      "transitions": [
        {
          "id": "instruction-data-complete",
          "priority": 1,
          "condition": {
            "all": [
              {"eq": ["instruction_review.attendance_complete", true]},
              {"eq": ["instruction_review.curriculum_complete", true]},
              {"exists": "instruction_review.interventions"},
              {"exists": "instruction_review.response_data"}
            ]
          },
          "destination": "access-language-review",
          "explanation": {
            "ar": "توفر وصف كافٍ لفرص التعليم والاستجابة ويمكن مراجعة السمع والبصر واللغة المنطوقة.",
            "en": "Instructional opportunity and response are sufficiently documented; hearing, vision, and spoken language can be reviewed."
          },
          "source_ids": ["ASHA-WRITTEN-LANGUAGE", "ASHA-WRITTEN-COMPONENTS"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        }
      ],
      "failure_behavior": "request_missing_data",
      "maximum_age_hours": 720
    },
    {
      "id": "access-language-review",
      "type": "record_review",
      "label": {"ar": "السمع والبصر واللغة المنطوقة", "en": "Hearing, vision, and spoken language"},
      "required_roles": ["speech_language_therapist", "educational_psychologist", "audiologist", "vision_specialist"],
      "preconditions": ["مراجعة التعليم"],
      "actions": [
        "التحقق من فحص السمع والبصر عند الحاجة",
        "مراجعة تاريخ اللغة والكلام والوعي الصوتي والتواصل",
        "تحديد أثر اللغة المنطوقة في القراءة والكتابة",
        "تحديد الحاجة لإحالة نطق ولغة أو وصول حسي"
      ],
      "assessment_ids": ["hearing-evaluation", "vision-functional-assessment", "language-communication-assessment"],
      "required_evidence": [
        "access_review.hearing_complete",
        "access_review.vision_complete",
        "spoken_language_review.completed",
        "access_review.validity_impact"
      ],
      "transitions": [
        {
          "id": "complete-access-or-language",
          "priority": 1,
          "condition": {
            "any": [
              {"eq": ["access_review.hearing_complete", false]},
              {"eq": ["access_review.vision_complete", false]},
              {"eq": ["spoken_language_review.completed", false]}
            ]
          },
          "destination": "specialist-prerequisite-assessment",
          "explanation": {
            "ar": "أحد متطلبات السمع أو البصر أو اللغة غير مكتمل ويلزم استكماله قبل تفسير التحصيل.",
            "en": "A hearing, vision, or spoken-language prerequisite is incomplete and must be addressed before achievement interpretation."
          },
          "source_ids": ["ASHA-WRITTEN-COMPONENTS", "ASHA-WRITTEN-LANGUAGE"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        },
        {
          "id": "prerequisites-complete",
          "priority": 2,
          "condition": {
            "all": [
              {"eq": ["access_review.hearing_complete", true]},
              {"eq": ["access_review.vision_complete", true]},
              {"eq": ["spoken_language_review.completed", true]},
              {"exists": "access_review.validity_impact"}
            ]
          },
          "destination": "multilingual-literacy-profile",
          "explanation": {
            "ar": "اكتملت متطلبات الوصول واللغة ويمكن بناء ملف القراءة والكتابة متعدد اللغات والأنظمة.",
            "en": "Access and spoken-language prerequisites are complete; a multilingual literacy profile can be developed."
          },
          "source_ids": ["ASHA-WRITTEN-COMPONENTS"],
          "requires_human_confirmation": false,
          "blocks_automation": false
        }
      ],
      "failure_behavior": "request_missing_data",
      "maximum_age_hours": 720
    },
    {
      "id": "specialist-prerequisite-assessment",
      "type": "medical_referral",
      "label": {"ar": "استكمال متطلبات الوصول واللغة", "en": "Complete access and language prerequisites"},
      "required_roles": ["speech_language_therapist", "audiologist", "vision_specialist", "clinical_reviewer"],
      "preconditions": ["توثيق مجال النقص"],
      "actions": [
        "استكمال التقييم التخصصي اللازم",
        "توثيق التكييفات والقيود وأثرها في الاختبارات الأكاديمية"
      ],
      "required_evidence": ["prerequisite_review.completed", "prerequisite_review.validity_impact"],
      "transitions": [
        {
          "id": "return-after-prerequisites",
          "priority": 1,
          "condition": {
            "all": [
              {"eq": ["prerequisite_review.completed", true]},
              {"exists": "prerequisite_review.validity_impact"},
              {"confirmed": "specialist-prerequisite-assessment:return-after-prerequisites"}
            ]
          },
          "destination": "multilingual-literacy-profile",
          "explanation": {
            "ar": "اكتملت المتطلبات التخصصية ويمكن متابعة ملف القراءة والكتابة وفق القيود.",
            "en": "Specialist prerequisites are complete; literacy profiling can continue with documented limitations."
          },
          "source_ids": ["ASHA-WRITTEN-COMPONENTS"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        }
      ],
      "failure_behavior": "stop_and_review",
      "maximum_age_hours": 2160
    },
    {
      "id": "multilingual-literacy-profile",
      "type": "interview",
      "label": {"ar": "الملف القرائي والكتابي متعدد اللغات", "en": "Multilingual literacy profile"},
      "required_roles": ["speech_language_therapist", "educational_psychologist", "qualified_interpreter"],
      "preconditions": ["متطلبات الوصول واللغة مكتملة"],
      "actions": [
        "توثيق اللغات المنطوقة والمكتوبة ونظم الكتابة ومدة التعرض والتعليم",
        "تحديد مهارات القراءة والكتابة المتوقعة حسب العمر والصف والمنهج",
        "تحديد صلاحية الدرجات المعيارية والحاجة لعينات أو تقييم ديناميكي"
      ],
      "required_evidence": [
        "literacy_profile.spoken_languages",
        "literacy_profile.written_languages",
        "literacy_profile.instruction_history",
        "literacy_profile.standard_score_eligibility"
      ],
      "transitions": [
        {
          "id": "literacy-profile-complete",
          "priority": 1,
          "condition": {
            "all": [
              {"count_gte": ["literacy_profile.spoken_languages", 1]},
              {"count_gte": ["literacy_profile.written_languages", 1]},
              {"exists": "literacy_profile.instruction_history"},
              {"exists": "literacy_profile.standard_score_eligibility"}
            ]
          },
          "destination": "learning-assessment-plan",
          "explanation": {
            "ar": "اكتمل ملف اللغات ونظم الكتابة والتعليم ويمكن تخطيط البطارية الأكاديمية واللغوية.",
            "en": "Languages, writing systems, and instructional history are documented; the academic and language battery can be planned."
          },
          "source_ids": ["ASHA-WRITTEN-LANGUAGE", "TESTING-STANDARDS"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        }
      ],
      "failure_behavior": "request_missing_data",
      "maximum_age_hours": 720
    },
    {
      "id": "learning-assessment-plan",
      "type": "team_review",
      "label": {"ar": "خطة تقييم القراءة والكتابة", "en": "Reading and writing assessment plan"},
      "required_roles": ["educational_psychologist", "speech_language_therapist", "special_educator", "clinical_reviewer"],
      "preconditions": ["ملف تعليم ولغة ووصول مكتمل"],
      "actions": [
        "اختيار قياسات فك الترميز والطلاقة والفهم والتهجئة والكتابة بحسب السؤال",
        "تقييم الوعي الصوتي والذاكرة الصوتية والتسمية السريعة واللغة المنطوقة عند الحاجة",
        "جمع عينات منهجية وملاحظة مباشرة وتقييم ديناميكي",
        "إضافة الانتباه أو القدرات المعرفية فقط للإجابة عن سؤال تفريقي محدد"
      ],
      "assessment_ids": [
        "academic-assessment-when-indicated",
        "language-communication-assessment",
        "cognitive-assessment-when-indicated",
        "conners-4"
      ],
      "required_evidence": [
        "assessment_plan.literacy_domains",
        "assessment_plan.tools",
        "assessment_plan.curriculum_samples",
        "assessment_plan.approved_by"
      ],
      "transitions": [
        {
          "id": "learning-plan-approved",
          "priority": 1,
          "condition": {
            "all": [
              {"count_gte": ["assessment_plan.literacy_domains", 2]},
              {"count_gte": ["assessment_plan.tools", 1]},
              {"eq": ["assessment_plan.curriculum_samples", true]},
              {"exists": "assessment_plan.approved_by"},
              {"confirmed": "learning-assessment-plan:learning-plan-approved"}
            ]
          },
          "destination": "evidence-collection",
          "explanation": {
            "ar": "اعتمدت خطة متعددة الطرق تشمل المهارات الأكاديمية وعينات المنهج والسياق التعليمي.",
            "en": "A multimethod plan covering academic skills, curriculum samples, and instructional context is approved."
          },
          "source_ids": ["ASHA-WRITTEN-LANGUAGE", "ASHA-WRITTEN-COMPONENTS", "TESTING-STANDARDS"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        }
      ],
      "failure_behavior": "stop_and_review",
      "maximum_age_hours": 720
    },
    {
      "id": "evidence-collection",
      "type": "assessment",
      "label": {"ar": "جمع أدلة القراءة والكتابة", "en": "Reading and writing evidence collection"},
      "required_roles": ["educational_psychologist", "speech_language_therapist", "qualified_assessor", "case_lead"],
      "preconditions": ["خطة وأدوات ومستخدمون معتمدون"],
      "actions": [
        "جمع الاختبارات وعينات المنهج والملاحظة وتقارير المتعلم والأسرة والمعلم",
        "توثيق الدقة والطلاقة والفهم والتهجئة والتعبير وفق السؤال",
        "ربط النتائج بالتعليم السابق والاستجابة للتدخل والوظيفة الصفية"
      ],
      "required_evidence": [
        "sources",
        "completed_assessments",
        "direct_observation.completed",
        "curriculum_samples.completed",
        "functional_profile.completed",
        "quality.material_conflict_unresolved"
      ],
      "transitions": [
        {
          "id": "learning-evidence-ready",
          "priority": 1,
          "condition": {
            "all": [
              {"count_gte": ["sources", 2]},
              {"count_gte": ["completed_assessments", 2]},
              {"eq": ["direct_observation.completed", true]},
              {"eq": ["curriculum_samples.completed", true]},
              {"eq": ["functional_profile.completed", true]},
              {"eq": ["quality.material_conflict_unresolved", false]}
            ]
          },
          "destination": "instruction-response-review",
          "explanation": {
            "ar": "اكتملت أدلة أكاديمية ووظيفية متعددة الطرق ويمكن دمجها مع جودة التعليم والاستجابة للتدخل.",
            "en": "Multimethod academic and functional evidence is complete and can be integrated with instructional quality and intervention response."
          },
          "source_ids": ["ASHA-WRITTEN-LANGUAGE", "ASHA-WRITTEN-COMPONENTS", "WHO-ICF"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        },
        {
          "id": "learning-material-conflict",
          "priority": 2,
          "condition": {"eq": ["quality.material_conflict_unresolved", true]},
          "destination": "conflict-review",
          "explanation": {
            "ar": "يوجد تعارض جوهري بين الاختبارات أو عينات الصف أو المصادر ويلزم تحليله.",
            "en": "A material conflict exists across tests, curriculum samples, or sources and requires review."
          },
          "source_ids": ["TESTING-STANDARDS"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        }
      ],
      "failure_behavior": "request_missing_data",
      "maximum_age_hours": 2160
    },
    {
      "id": "conflict-review",
      "type": "team_review",
      "label": {"ar": "مراجعة التعارض الأكاديمي", "en": "Academic evidence conflict review"},
      "required_roles": ["educational_psychologist", "speech_language_therapist", "clinical_reviewer"],
      "preconditions": ["توثيق التعارض"],
      "actions": [
        "فحص اختلاف اللغة والمنهج والمهمة والتوقيت والمجيب وصلاحية الاختبار",
        "طلب عينة أو قياس إضافي محدد عند الحاجة",
        "توثيق أثر التعارض أو إبقاء النتيجة غير حاسمة"
      ],
      "required_evidence": ["quality.conflict_analysis", "quality.conflict_resolution"],
      "transitions": [
        {
          "id": "learning-conflict-resolved",
          "priority": 1,
          "condition": {
            "all": [
              {"eq": ["quality.material_conflict_unresolved", false]},
              {"exists": "quality.conflict_resolution"},
              {"confirmed": "conflict-review:learning-conflict-resolved"}
            ]
          },
          "destination": "instruction-response-review",
          "explanation": {
            "ar": "حل التعارض أو وثقت حدوده ويمكن متابعة مراجعة التعليم والاستجابة.",
            "en": "The conflict is resolved or its limits documented; instruction and response review can proceed."
          },
          "source_ids": ["ASHA-WRITTEN-LANGUAGE", "TESTING-STANDARDS"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        }
      ],
      "failure_behavior": "stop_and_review",
      "maximum_age_hours": 720
    },
    {
      "id": "instruction-response-review",
      "type": "team_review",
      "label": {"ar": "مراجعة التعليم والاستجابة للتدخل", "en": "Instruction and intervention response review"},
      "required_roles": ["educational_psychologist", "special_educator", "speech_language_therapist", "case_lead"],
      "preconditions": ["أدلة أكاديمية ووظيفية صالحة"],
      "actions": [
        "مقارنة متطلبات المنهج بالأداء دون مساعدة ومع الدعم",
        "مراجعة كثافة ومدة ودقة تنفيذ التدخل والاستجابة",
        "تحديد ما إذا كان نقص التعليم أو اللغة يفسر الأداء بصورة أساسية",
        "تسجيل المعلومات الناقصة والشكوك"
      ],
      "required_evidence": [
        "instruction_response.review_completed",
        "instruction_response.intervention_fidelity",
        "instruction_response.response_pattern",
        "instruction_response.remaining_uncertainties"
      ],
      "transitions": [
        {
          "id": "instruction-response-complete",
          "priority": 1,
          "condition": {
            "all": [
              {"eq": ["instruction_response.review_completed", true]},
              {"exists": "instruction_response.intervention_fidelity"},
              {"exists": "instruction_response.response_pattern"},
              {"exists": "instruction_response.remaining_uncertainties"},
              {"confirmed": "instruction-response-review:instruction-response-complete"}
            ]
          },
          "destination": "differential-review",
          "explanation": {
            "ar": "اكتملت مراجعة التعليم والاستجابة ويمكن فحص التفسيرات البديلة والظروف المصاحبة.",
            "en": "Instruction and intervention response are reviewed; alternative explanations and coexisting conditions can be assessed."
          },
          "source_ids": ["ASHA-WRITTEN-LANGUAGE", "ASHA-WRITTEN-COMPONENTS"],
          "requires_human_confirmation": true,
          "blocks_automation": true
        }
      ],
      "failure_behavior": "stop_and_review",
      "maximum_age_hours": 720
    },
    {
      "id": "differential-review",
      "type": "team_review",
      "label": {"ar": "المراجعة التفريقية", "en": "Differential review"},
      "required_roles": ["educational_psychologist", "speech_language_therapist", "clinical_reviewer"],
      "preconditions": ["مراجعة التعليم والاستجابة"],
      "actions": [
        "مراجعة اللغة والكلام والسمع والبصر والانتباه والقدرات المعرفية والحالة النفسية عند وجود مؤشر",
        "تحديد ما إذا كانت العوامل الأخرى تفسر الأداء أو توجد بصورة مصاحبة",
        "عدم استبعاد اضطراب تعلم لمجرد وجود حالة أخرى دون تحليل"
      ],
      "required_evidence": [
        "differential_review.completed",
        "differential_review.conditions_considered",
        "differential_review.decision",
        "differential_review.limitations"
      ],
      "transitions": [
        {
          "id": "learning-differential-complete",
          "priority": 1,
