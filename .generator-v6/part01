STYLE = r'''
:root{--bg:#07151b;--panel:#10252d;--panel2:#15323b;--ink:#f5f0e7;--muted:#b8c6c8;--gold:#d2a75e;--teal:#48aaa1;--line:#ffffff18;--danger:#e4a5a5}
