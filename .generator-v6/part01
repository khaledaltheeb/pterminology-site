APP = r'''
const terms=window.TERMS||[];const q=document.querySelector("#q"),grid=document.querySelector("#terms-grid"),count=document.querySelector("#result-count"),filters=document.querySelectorAll(".filter");let active="الكل";
const norm=s=>(s||"").toLowerCase().normalize("NFKD").replace(/[ًٌٍَُِّْـ]/g,"").replace(/[إأآ]/g,"ا").replace(/ى/g,"ي");
function render(){if(!grid)return;let x=norm(q?.value||"");let list=terms.filter(t=>(active==="الكل"||t.category===active)&&(!x||norm(`${t.ar} ${t.en} ${t.description} ${t.category}`).includes(x)));grid.innerHTML=list.slice(0,200).map(t=>`<a class="card" href="${window.BASE}terms/${t.slug}/"><small>${String(t.id).padStart(3,"0")}</small><h3>${t.ar}</h3><div class="en">${t.en}</div><p class="desc">${t.description}</p><span class="tag">${t.category}</span></a>`).join("")||`<div class="empty">لا توجد نتائج مطابقة. جرّب كلمة أقصر أو تصنيفًا آخر.</div>`;if(count)count.textContent=`${list.length} نتيجة`;}
q?.addEventListener("input",render);filters.forEach(b=>b.addEventListener("click",()=>{filters.forEach(x=>x.classList.remove("active"));b.classList.add("active");active=b.dataset.cat;render()}));
document.addEventListener("keydown",e=>{if(e.key==="/"&&document.activeElement!==q){e.preventDefault();q?.focus()}});
document.querySelector("#random")?.addEventListener("click",()=>{location.href=window.BASE+"terms/"+terms[Math.floor(Math.random()*terms.length)].slug+"/"});
const favKey="pterminology-favorites";function favs(){return JSON.parse(localStorage.getItem(favKey)||"[]")}document.querySelectorAll("[data-fav]").forEach(b=>{let s=b.dataset.fav;b.classList.toggle("on",favs().includes(s));b.onclick=()=>{let f=favs();f=f.includes(s)?f.filter(x=>x!==s):[...f,s];localStorage.setItem(favKey,JSON.stringify(f));b.classList.toggle("on",f.includes(s));b.textContent=f.includes(s)?"محفوظ ★":"حفظ ☆"}});
if("serviceWorker"in navigator)navigator.serviceWorker.register(window.BASE+"service-worker.js").catch(()=>{});
render();
'''

